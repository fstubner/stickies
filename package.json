{
  "name": "stickies",
  "version": "0.1.0",
  "type": "module",
  "description": "A cross-platform desktop application for creating and managing sticky notes",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:svelte": "node scripts/dev-svelte.cjs",
    "build:electron": "tsc -p tsconfig.node.json && node scripts/rename-electron-output.cjs",
    "dev:electron": "node scripts/dev-electron.cjs",
    "build": "npm run build:svelte && npm run build:electron",
    "build:svelte": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "sticky notes",
    "task management",
    "productivity",
    "electron",
    "svelte"
  ],
  "author": "Felix Stubner",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tsconfig/svelte": "^5.0.0",
    "@types/node": "^22.15.17",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.5.6",
    "svelte": "^4.2.3",
    "svelte-check": "^3.6.0",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "@xyflow/svelte": "^0.1.39",
    "bits-ui": "^0.21.16",
    "clsx": "^2.1.1",
    "electron-store": "^8.1.0",
    "gray-matter": "^4.0.3",
    "lucide-svelte": "^0.300.0",
    "marked": "^9.1.5",
    "mermaid": "^11.12.2",
    "svelte-routing": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.stickies.app",
    "productName": "Stickies",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Editor"
      }
    ]
  }
}